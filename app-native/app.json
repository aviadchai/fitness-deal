{
  "expo": {
    "name": "Fitness Deal",
    "slug": "fitness-deal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fitness-deal",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aviadchai.fitnessdeal",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used for automatic push-up counting",
        "NSMotionUsageDescription": "Step counting for fitness tracking"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.aviadchai.fitnessdeal"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ]
  }
}
